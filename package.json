{
  "name": "claude-tmux-focus",
  "displayName": "Claude Tmux Focus",
  "publisher": "songsub-leo-lee",
  "description": "Open Claude Code in a tmux session in the editor area with a single shortcut",
  "version": "1.0.4",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fitree/vscode-claude-tmux"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "tmux",
    "terminal",
    "ai",
    "claude-code"
  ],
  "activationEvents": [
    "onCommand:claude-tmux-focus.open",
    "onCommand:claude-tmux-focus.focusWindow",
    "onCommand:claude-tmux-focus.createWindow",
    "onCommand:claude-tmux-focus.createNew",
    "onCommand:claude-tmux-focus.remove",
    "onCommand:claude-tmux-focus.prevSession",
    "onCommand:claude-tmux-focus.nextSession"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-tmux-focus.open",
        "title": "Claude Tmux: Focus"
      },
      {
        "command": "claude-tmux-focus.focusWindow",
        "title": "Claude Tmux: Focus Window"
      },
      {
        "command": "claude-tmux-focus.createWindow",
        "title": "Claude Tmux: Connect Claude Code Session"
      },
      {
        "command": "claude-tmux-focus.createNew",
        "title": "Claude Tmux: Create New"
      },
      {
        "command": "claude-tmux-focus.remove",
        "title": "Claude Tmux: Remove"
      },
      {
        "command": "claude-tmux-focus.prevSession",
        "title": "Claude Tmux: Focus on Previous Session"
      },
      {
        "command": "claude-tmux-focus.nextSession",
        "title": "Claude Tmux: Focus on Next Session"
      }
    ],
    "keybindings": [
      {
        "command": "claude-tmux-focus.open",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      },
      {
        "command": "claude-tmux-focus.prevSession",
        "key": "ctrl+shift+,",
        "mac": "cmd+shift+,"
      },
      {
        "command": "claude-tmux-focus.nextSession",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+."
      }
    ]
  }
}
